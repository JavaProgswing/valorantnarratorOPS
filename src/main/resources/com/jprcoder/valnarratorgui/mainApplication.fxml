<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXToggleButton?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<StackPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="680.0" prefWidth="400.0"
           style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12"
           fx:controller="com.jprcoder.valnarratorgui.ValNarratorController">
    <padding>
        <Insets bottom="10" left="10" right="10" top="10"/>
    </padding>

    <VBox styleClass="app-card">

        <!-- ===== NAV BAR (inside the card) ===== -->
        <HBox fx:id="topBar" alignment="CENTER_LEFT" styleClass="nav-bar">
            <padding>
                <Insets bottom="0" left="18" right="16" top="0"/>
            </padding>
            <Label styleClass="brand" text="VAL">
                <graphic>
                    <Label styleClass="brand-accent" text="NARRATOR"/>
                </graphic>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="14">
                <ImageView fx:id="btnUser" fitHeight="24" fitWidth="24" onMouseClicked="#handleButtonAction"
                           opacity="0.4" pickOnBounds="true" preserveRatio="true" styleClass="nav-icon">
                    <Image url="@user.png"/>
                </ImageView>
                <ImageView fx:id="btnInfo" fitHeight="24" fitWidth="24" onMouseClicked="#handleButtonAction"
                           opacity="0.4" pickOnBounds="true" preserveRatio="true" styleClass="nav-icon">
                    <Image url="@info.png"/>
                </ImageView>
                <ImageView fx:id="btnSettings" fitHeight="24" fitWidth="24" onMouseClicked="#handleButtonAction"
                           opacity="0.4" pickOnBounds="true" preserveRatio="true" styleClass="nav-icon">
                    <Image url="@setting.png"/>
                </ImageView>
                <Separator orientation="VERTICAL" prefHeight="22"/>
                <ImageView fx:id="btnPower" fitHeight="22" fitWidth="22" onMouseClicked="#handleButtonAction"
                           opacity="0.4" pickOnBounds="true" preserveRatio="true" styleClass="nav-icon">
                    <Image url="@power.png"/>
                </ImageView>
            </HBox>
        </HBox>

        <!-- ===== CONTENT AREA (one panel visible) ===== -->
        <StackPane fx:id="contentArea" styleClass="content-area" VBox.vgrow="ALWAYS">

            <!-- ===== LOADING / LOGIN ===== -->
            <VBox fx:id="panelLogin" alignment="CENTER" spacing="0" styleClass="tab">
                <padding>
                    <Insets bottom="22" left="26" right="26" top="22"/>
                </padding>
                <Region VBox.vgrow="ALWAYS"/>
                <VBox alignment="CENTER" spacing="16">
                    <ProgressIndicator prefHeight="54.0" prefWidth="54.0" styleClass="login-spinner"/>
                    <Label styleClass="tab-title" text="Starting up"/>
                    <Label fx:id="progressStatusLabel" styleClass="status-chip" text="STATUS"/>
                    <Label fx:id="progressLoginLabel" maxWidth="300" styleClass="status-text"
                           text="Preparing to start Valorant" textAlignment="CENTER" wrapText="true"/>
                    <ProgressBar fx:id="progressLogin" prefHeight="8.0" prefWidth="260.0" progress="-1.0"/>
                    <Label maxWidth="300" styleClass="hint-text" text="Switches automatically when ready."
                           textAlignment="CENTER" wrapText="true"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <VBox alignment="CENTER" spacing="8">
                    <Label maxWidth="300" styleClass="hint-text" text="Need help? Join our Discord."
                           textAlignment="CENTER" wrapText="true"/>
                    <Button onAction="#openDiscordInvite" styleClass="ghost-button" text="Join our Discord"/>
                </VBox>
            </VBox>

            <!-- ===== NARRATOR (user) ===== -->
            <VBox fx:id="panelUser" spacing="16" styleClass="tab" visible="false">
                <padding>
                    <Insets bottom="20" left="24" right="24" top="20"/>
                </padding>
                <StackPane alignment="CENTER_LEFT">
                    <Label fx:id="windowTitle" styleClass="tab-title-accent" text="Narrator"/>
                    <Label fx:id="premiumWindowTitle" styleClass="tab-title-premium" text="Narrator" visible="false"/>
                </StackPane>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label styleClass="section-header" text="NARRATOR VOICE"/>
                        <Label styleClass="section-desc" text="Voice used for text narration." wrapText="true"/>
                    </VBox>
                    <ComboBox fx:id="voices" onAction="#selectVoice" onHidden="#hideVoices" onShown="#showVoices"
                              prefWidth="170" promptText="Matthew, male" styleClass="app-combo">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Matthew, male"/>
                                <String fx:value="Justin, male"/>
                                <String fx:value="Joey, male"/>
                                <String fx:value="Brian, male"/>
                                <String fx:value="Joanna, female"/>
                                <String fx:value="Ivy, female"/>
                                <String fx:value="Kendra, female"/>
                                <String fx:value="Kajal, female"/>
                                <String fx:value="Astra, VALORANT"/>
                                <String fx:value="Breach, VALORANT"/>
                                <String fx:value="Brimstone, VALORANT"/>
                                <String fx:value="Chamber, VALORANT"/>
                                <String fx:value="Clove, VALORANT"/>
                                <String fx:value="Cypher, VALORANT"/>
                                <String fx:value="Deadlock, VALORANT"/>
                                <String fx:value="Fade, VALORANT"/>
                                <String fx:value="Gekko, VALORANT"/>
                                <String fx:value="Harbor, VALORANT"/>
                                <String fx:value="Jett, VALORANT"/>
                                <String fx:value="KAYO, VALORANT"/>
                                <String fx:value="Killjoy, VALORANT"/>
                                <String fx:value="Neon, VALORANT"/>
                                <String fx:value="Omen, VALORANT"/>
                                <String fx:value="Phoenix, VALORANT"/>
                                <String fx:value="Raze, VALORANT"/>
                                <String fx:value="Reyna, VALORANT"/>
                                <String fx:value="Tejo, VALORANT"/>
                                <String fx:value="Sage, VALORANT"/>
                                <String fx:value="Skye, VALORANT"/>
                                <String fx:value="Sova, VALORANT"/>
                                <String fx:value="Viper, VALORANT"/>
                                <String fx:value="Veto, VALORANT"/>
                                <String fx:value="Vyse, VALORANT"/>
                                <String fx:value="Yoru, VALORANT"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </HBox>

                <VBox spacing="4">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="section-header" text="NARRATOR RATE"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="rateValueLabel" styleClass="stat-value" text="100%"/>
                    </HBox>
                    <Label styleClass="section-desc" text="Speaking speed for text narration."/>
                    <Slider fx:id="rateSlider" majorTickUnit="50.0" max="200.0" maxWidth="Infinity" minorTickCount="0"
                            showTickLabels="false" showTickMarks="false" snapToTicks="false" value="100.0">
                        <VBox.margin>
                            <Insets left="2" right="2"/>
                        </VBox.margin>
                    </Slider>
                </VBox>

                <Separator styleClass="soft-sep"/>

                <Label styleClass="section-header" text="TODAY'S STATS"/>
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints/>
                        <RowConstraints/>
                    </rowConstraints>
                    <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label fx:id="messagesSentLabel" styleClass="stat-card-value" text="0"/>
                        <Label styleClass="stat-card-label" text="Messages"/>
                    </VBox>
                    <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label fx:id="charactersNarratedLabel" styleClass="stat-card-value" text="0"/>
                        <Label styleClass="stat-card-label" text="Characters"/>
                    </VBox>
                    <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label fx:id="wordsSentLabel" styleClass="stat-card-value" text="0"/>
                        <Label styleClass="stat-card-label" text="Words"/>
                    </VBox>
                    <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label fx:id="avgLengthLabel" styleClass="stat-card-value" text="0"/>
                        <Label styleClass="stat-card-label" text="Avg. chars"/>
                    </VBox>
                </GridPane>

                <Separator styleClass="soft-sep"/>

                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="section-header" text="REMAINING QUOTA" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label styleClass="section-desc" text="Messages left in today's quota."/>
                    <ProgressBar fx:id="quotaBar" maxWidth="Infinity" prefHeight="12" progress="1.0"/>
                </VBox>
            </VBox>

            <!-- ===== SETTINGS ===== -->
            <VBox fx:id="panelSettings" styleClass="tab" visible="false">
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="tab-scroll" vbarPolicy="AS_NEEDED"
                            VBox.vgrow="ALWAYS">
                    <VBox spacing="13">
                        <padding>
                            <Insets bottom="10" left="24" right="20" top="20"/>
                        </padding>
                        <Label styleClass="tab-title-accent" text="Settings"/>

                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="section-header" text="NARRATOR SOURCE"/>
                                <Label styleClass="section-desc" text="Which chats to narrate." wrapText="true"/>
                            </VBox>
                            <ComboBox fx:id="sources" onAction="#selectSource" prefWidth="150" promptText="SELF"
                                      styleClass="app-combo">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="SELF"/>
                                        <String fx:value="TEAM"/>
                                        <String fx:value="TEAM+ALL"/>
                                        <String fx:value="SELF+TEAM+ALL"/>
                                        <String fx:value="PARTY"/>
                                        <String fx:value="PARTY+ALL"/>
                                        <String fx:value="SELF+PARTY+ALL"/>
                                        <String fx:value="PARTY+TEAM"/>
                                        <String fx:value="PARTY+TEAM+ALL"/>
                                        <String fx:value="SELF+PARTY+TEAM+ALL"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="section-header" text="PRIVATE MESSAGES"/>
                                <Label styleClass="section-desc" text="Allow whispers to be narrated." wrapText="true"/>
                            </VBox>
                            <JFXToggleButton fx:id="privateChatButton" onAction="#togglePrivateMessages"
                                             toggleColor="WHITE"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="section-header" text="SYSTEM MIC"/>
                                <Label styleClass="section-desc" text="Stream your default mic alongside the narrator."
                                       wrapText="true"/>
                            </VBox>
                            <JFXToggleButton fx:id="micButton" onAction="#toggleMic" toggleColor="WHITE"/>
                        </HBox>

                        <VBox spacing="6" styleClass="row">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label styleClass="section-header" text="TEAM PUSH-TO-TALK KEY"/>
                                    <Label fx:id="keybindText" styleClass="section-desc"
                                           text="Push-to-talk key for team voice." wrapText="true"/>
                                </VBox>
                                <TextField fx:id="keybindTextField" onKeyPressed="#keybindChange"
                                           onMouseDragEntered="#enterKeybind" onMouseDragExited="#exitKeybind"
                                           onMouseEntered="#enterKeybind" onMouseExited="#exitKeybind" prefWidth="120"
                                           promptText="Press a key" styleClass="key-field"/>
                            </HBox>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="section-header" text="AUTO TEAM KEY"/>
                                <Label styleClass="section-desc" text="Hold the team key automatically while narrating."
                                       wrapText="true"/>
                            </VBox>
                            <JFXToggleButton fx:id="teamChatButton" onAction="#toggleTeamChat" selected="true"
                                             toggleColor="WHITE"/>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="section-header" text="SYNC VOICE SETTINGS"/>
                                <Label styleClass="section-desc" text="Sync settings to Valorant on start-up."
                                       wrapText="true"/>
                            </VBox>
                            <JFXToggleButton fx:id="valorantSettings" onAction="#syncValorantSettingsToggle"
                                             selected="true" toggleColor="WHITE"/>
                        </HBox>

                        <VBox spacing="6" styleClass="row">
                            <Label styleClass="section-header" text="IGNORE PLAYER MESSAGES"/>
                            <Label styleClass="section-desc" text="Type to ignore, or select an entry to toggle."/>
                            <ComboBox fx:id="playerDropdown" editable="true" maxWidth="Infinity"
                                      onAction="#handlePlayerAction" promptText="Type to ignore / select to toggle"
                                      styleClass="app-combo">
                                <items>
                                    <FXCollections fx:factory="observableArrayList"/>
                                </items>
                            </ComboBox>
                        </VBox>

                    </VBox>
                </ScrollPane>
                <HBox spacing="10" styleClass="settings-actions">
                    <padding>
                        <Insets bottom="16" left="24" right="20" top="12"/>
                    </padding>
                    <Button fx:id="voiceSettingsSync" maxWidth="Infinity" onAction="#syncValorantSettings"
                            styleClass="ghost-button" text="Sync to Valorant" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="fullFormsButton" maxWidth="Infinity" onAction="#openFullFormsManager"
                            styleClass="primary-button" text="Full-forms" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- ===== ACCOUNT (info) ===== -->
            <VBox fx:id="panelInfo" alignment="TOP_CENTER" spacing="14" styleClass="tab" visible="false">
                <padding>
                    <Insets bottom="20" left="24" right="24" top="22"/>
                </padding>
                <ImageView fitHeight="84" fitWidth="84" pickOnBounds="true" preserveRatio="true">
                    <Image url="@userBIG.png"/>
                </ImageView>
                <Label styleClass="tab-title-accent" text="Account"/>
                <Label fx:id="premiumBadge" styleClass="free-badge" text="FREE"/>

                <GridPane hgap="12" maxWidth="320" vgap="14">
                    <columnConstraints>
                        <ColumnConstraints minWidth="90"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label styleClass="stat-key" text="User ID" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="userIDLabel" editable="false" styleClass="copyable-text-field"
                               stylesheets="@styles.css" text="N/A" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label styleClass="stat-key" text="Quota left" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="quotaLabel" styleClass="stat-value-left" text="999/999" GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>
                    <Label styleClass="stat-key" text="Premium" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="premiumDateLabel" styleClass="stat-value-left" text="Valid till DD-MM-YYYY HH:MM"
                           wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <rowConstraints>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                    </rowConstraints>
                </GridPane>

                <Button fx:id="subscribeButton" maxWidth="320" onAction="#browseSubscription"
                        styleClass="premium-button" text="View subscription info"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Label maxWidth="300" styleClass="hint-text" text="Need help? Join our Discord." textAlignment="CENTER"
                       wrapText="true"/>
                <Button onAction="#openDiscordInvite" styleClass="ghost-button" text="Join our Discord"/>
            </VBox>

            <!-- ===== PAUSED OVERLAY (narration disabled) ===== -->
            <VBox fx:id="disabledOverlay" alignment="CENTER" pickOnBounds="true" spacing="12"
                  styleClass="paused-overlay" visible="false">
                <Label styleClass="paused-title" text="Narration paused"/>
                <Label maxWidth="240" styleClass="paused-desc" text="Press the power button to resume narrating."
                       textAlignment="CENTER" wrapText="true"/>
            </VBox>

        </StackPane>
    </VBox>
</StackPane>
